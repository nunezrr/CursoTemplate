    {
      "name": "02 - GET Detalle de un usuario",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Status 200\r",
              "pm.test('Status es 200 OK', function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "//JSON Schema con id, name, username, email obligatorios\r",
              "// Contrato de la API: si la estructura cambia, este test falla\r",
              "// 1. Definimos el esquema esperado (el contrato de la API)\r",
              "const schema = {\r",
              "    \"type\": \"object\",\r",
              "    \"required\": [\"id\", \"name\", \"username\", \"email\", \"address\", \"phone\", \"website\", \"company\"],\r",
              "    \"properties\": {\r",
              "        \"id\": { \"type\": \"integer\" },\r",
              "        \"name\": { \"type\": \"string\" },\r",
              "        \"username\": { \"type\": \"string\" },\r",
              "        \"email\": { \"type\": \"string\", \"format\": \"email\" }, // Valida que tenga estructura de correo\r",
              "        \"address\": {\r",
              "            \"type\": \"object\",\r",
              "            \"required\": [\"street\", \"suite\", \"city\", \"zipcode\", \"geo\"],\r",
              "            \"properties\": {\r",
              "                \"street\": { \"type\": \"string\" },\r",
              "                \"suite\": { \"type\": \"string\" },\r",
              "                \"city\": { \"type\": \"string\" },\r",
              "                \"zipcode\": { \"type\": \"string\" },\r",
              "                \"geo\": {\r",
              "                    \"type\": \"object\",\r",
              "                    \"required\": [\"lat\", \"lng\"],\r",
              "                    \"properties\": {\r",
              "                        \"lat\": { \"type\": \"string\" },\r",
              "                        \"lng\": { \"type\": \"string\" }\r",
              "                    }\r",
              "                }\r",
              "            }\r",
              "        },\r",
              "        \"phone\": { \"type\": \"string\" },\r",
              "        \"website\": { \"type\": \"string\" },\r",
              "        \"company\": {\r",
              "            \"type\": \"object\",\r",
              "            \"required\": [\"name\", \"catchPhrase\", \"bs\"],\r",
              "            \"properties\": {\r",
              "                \"name\": { \"type\": \"string\" },\r",
              "                \"catchPhrase\": { \"type\": \"string\" },\r",
              "                \"bs\": { \"type\": \"string\" }\r",
              "            }\r",
              "        }\r",
              "    }\r",
              "};\r",
              "\r",
              "// 2. Validamos que el JSON de respuesta cumpla con el esquema definido\r",
              "pm.test(\"El contrato de la API es válido (JSON Schema)\", function () {\r",
              "    const responseData = pm.response.json();\r",
              "    \r",
              "    // ajv es el validador que Postman trae por defecto en su entorno\r",
              "    const Ajv = require('ajv');\r",
              "    const ajv = new Ajv({ allErrors: true }); // 'allErrors' ayuda a reportar todos los fallos juntos\r",
              "    \r",
              "    const validate = ajv.compile(schema);\r",
              "    const valid = validate(responseData);\r",
              "    \r",
              "    // Si la validación falla, imprimimos los detalles en la consola de Postman\r",
              "    if (!valid) {\r",
              "        console.error(\"Detalles de fallas en el contrato:\", ajv.errorsText(validate.errors));\r",
              "    }\r",
              "    \r",
              "    pm.expect(valid).to.be.true;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "1"
          ]
        }
      },
      "response": []
    },
    {
      "name": "03 - POST Crea un usuario",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Status 201\r",
              "pm.test('Status es 201 OK', function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "//el name enviado (generado en pre-request con Date.now()) coincide con el devuelto\r",
              "pm.test(\"El nombre devuelto coincide con el nombre dinámico generado\", function () {\r",
              "    // 1. Obtenemos el valor actual de la variable de colección\r",
              "    const nombreEsperado = pm.collectionVariables.get('dynamic_name');\r",
              "    \r",
              "    // 2. Obtenemos el valor de la propiedad 'name' en la respuesta del servidor\r",
              "    const responseData = pm.response.json();\r",
              "    const nombreRecibido = responseData.name;\r",
              "    \r",
              "    // Log útil para la consola de Postman en caso de que queramos verificar\r",
              "    console.log(`Comparando: Esperado [${nombreEsperado}] vs Recibido [${nombreRecibido}]`);\r",
              "    \r",
              "    // 3. Validamos que ambos valores sean exactamente iguales\r",
              "    pm.expect(nombreRecibido).to.eql(nombreEsperado);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Se ejecuta ANTES de enviar el request: genera un name\r",
              "const name = 'RNR ' + Date.now();\r",
              "pm.collectionVariables.set('dynamic_name', name);\r",
              "console.log('Nombre generado:', name);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\": \"{{dynamic_name}}\",\r\n    \"username\": \"Bret\",\r\n    \"email\": \"Sincere@april.biz\",\r\n    \"address\": {\r\n        \"street\": \"Kulas Light\",\r\n        \"suite\": \"Apt. 556\",\r\n        \"city\": \"Gwenborough\",\r\n        \"zipcode\": \"92998-3874\",\r\n        \"geo\": {\r\n            \"lat\": \"-37.3159\",\r\n            \"lng\": \"81.1496\"\r\n        }\r\n    },\r\n    \"phone\": \"1-770-736-8031 x56442\",\r\n    \"website\": \"hildegard.org\",\r\n    \"company\": {\r\n        \"name\": \"Romaguera-Crona\",\r\n        \"catchPhrase\": \"Multi-layered client-server neural-net\",\r\n        \"bs\": \"harness real-time e-markets\"\r\n    }\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/users",
          "host": [
            "{{base_url}}"
          ],
