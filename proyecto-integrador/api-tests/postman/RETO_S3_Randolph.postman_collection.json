    {
      "name": "06 - GET Inexistente (negativo)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Validar que el código de estado sea exactamente 404 (Not Found)\r",
              "pm.test(\"El código de estado es 404 Not Found\", function () {\r",
              "    pm.response.to.have.status(404);\r",
