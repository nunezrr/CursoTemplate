              "    \r",
              "    // 2. Extraemos el email que nos devolvió el servidor\r",
              "    const emailRecibido = responseData.email;\r",
              "    \r",
              "    console.log(`Comparando Email - Esperado: ${emailEsperado} | Recibido: ${emailRecibido}`);\r",
              "    \r",
              "    // 3. Validamos que coincidan perfectamente\r",
              "    pm.expect(emailRecibido).to.eql(emailEsperado);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "//Genera un e-mail dinamico\r",
              "const dynamicEmail = 'user1.' + Date.now() + '@testdomain.com';\r",
              "\r",
              "// Guardamos el correo en una variable de colección\r",
              "pm.collectionVariables.set('updated_email', dynamicEmail);\r",
              "\r",
              "console.log('Nuevo email para actualizar:', dynamicEmail);"
            ],
            "type": "text/javascript",
